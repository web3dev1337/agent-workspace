# Development Instance Configuration  
ORCHESTRATOR_PORT=4000
ORCHESTRATOR_HOST=127.0.0.1
CLIENT_PORT=2081
TAURI_DEV_PORT=1421
DIFF_VIEWER_PORT=7656
DIFF_VIEWER_HOST=127.0.0.1
LOG_LEVEL=info
NODE_ENV=development
ENABLE_FILE_WATCHING=true

# Agent Workspace directories (defaults shown; override to customize)
# AGENT_WORKSPACE_DIR=~/.agent-workspace
# AGENT_WORKSPACE_PROJECTS_DIR=~/.agent-workspace/projects

# Set to 1 to also scan ~/GitHub for repos (legacy mode, off by default)
# LEGACY_GITHUB_SCAN=0
