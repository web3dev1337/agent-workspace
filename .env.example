# Server Configuration
PORT=3000
HOST=0.0.0.0

# Security
# Optional authentication token - uncomment and set to enable auth
# AUTH_TOKEN=your-secret-token-here

# Worktree Configuration
# Base path for worktrees (defaults to /home/ab)
# WORKTREE_BASE_PATH=/home/ab

# Number of worktrees (defaults to 8)
# WORKTREE_COUNT=8

# Session Configuration
# Session timeout in milliseconds (defaults to 30 minutes)
# SESSION_TIMEOUT=1800000

# Max processes per session (prevent fork bombs)
# MAX_PROCESSES_PER_SESSION=50

# Logging
# Log level: error, warn, info, verbose, debug
LOG_LEVEL=info

# Token tracking
# Claude's max context tokens
MAX_CONTEXT_TOKENS=200000