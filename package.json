{
  "name": "agent-workspace",
  "version": "0.1.13",
  "description": "Multi-terminal orchestrator for Claude Code sessions",
  "main": "server/index.js",
  "scripts": {
    "start": "npm run dev",
    "dev:server": "node scripts/ensure-pty.js && nodemon server/index.js",
    "dev:client": "node client/dev-server.js",
    "dev:diff": "cd diff-viewer && npm run dev",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "node scripts/tauri/run-tauri-build.js --profile release",
    "tauri:build:fast": "node scripts/tauri/run-tauri-build.js --profile fast",
    "tauri:build:arch": "node scripts/tauri/run-tauri-build.js --profile fast --bundles pacman",
    "release:sync-version": "node scripts/tauri/sync-tauri-version.js",
    "release:check-version": "node scripts/release/check-version-consistency.js",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:full": "concurrently \"npm run dev:server\" \"npm run dev:client\" \"npm run tauri:dev\"",
    "prod": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:web": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:web:safe": "ORCHESTRATOR_PORT=4001 CLIENT_PORT=4100 npm run dev:web",
    "site:preview": "node scripts/preview-site.js",
    "site:legal": "node scripts/render-legal-pages.js",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "jest",
    "test:e2e": "node scripts/run-e2e-safe.js",
    "test:e2e:unsafe": "playwright test",
    "test:e2e:safe": "node scripts/run-e2e-safe.js",
    "test:e2e:diff-viewer": "node scripts/run-e2e-diff-viewer.js",
    "test:e2e:proxy": "ORCHESTRATOR_TEST_PORT=4001 CLIENT_TEST_PORT=4100 playwright test --config playwright.proxy.config.js",
    "test:e2e:headed": "playwright test --headed",
    "test:create-project": "jest tests/unit/createProjectScript.test.js",
    "test:coverage": "jest --coverage",
    "check:command-surface": "node scripts/check-command-surface-drift.js",
    "audit:public-release": "node scripts/public-release-audit.js",
    "audit:public-release:history": "node scripts/public-release-audit.js --history-secrets",
    "audit:history-authors": "node scripts/audit-history-authors.js",
    "prep:history-rewrite": "node scripts/generate-history-rewrite-workkit.js",
    "prep:history-rewrite:pipeline": "node scripts/run-history-rewrite-prep.js",
    "prep:history-rewrite:mailmap-finalize": "node scripts/finalize-history-rewrite-mailmap.js",
    "prep:public-snapshot-repo": "node scripts/create-public-snapshot-repo.js",
    "history-rewrite:execute:plan": "node scripts/execute-history-rewrite.js",
    "report:release-readiness": "node scripts/generate-release-readiness-report.js",
    "setup:history-rewrite-tools": "node scripts/setup-history-rewrite-tools.js",
    "check:history-rewrite-readiness": "node scripts/check-history-rewrite-readiness.js",
    "check:history-rewrite-readiness:strict": "node scripts/check-history-rewrite-readiness.js --strict --require-gitleaks",
    "check:history-rewrite-result": "node scripts/verify-history-rewrite-result.js",
    "check:history-rewrite-result:advisory": "node scripts/verify-history-rewrite-result.js --advisory",
    "check:public-snapshot-repo": "node scripts/verify-public-snapshot-repo.js"
  },
  "keywords": [
    "claude",
    "ai",
    "orchestrator",
    "terminal",
    "websocket"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "concurrently": "^9.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "http-proxy-middleware": "^3.0.5",
    "multer": "^2.0.2",
    "node-pty": "1.2.0-beta.12",
    "socket.io": "^4.6.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@tauri-apps/cli": "^2.0.0-rc.18",
    "@types/jest": "^30.0.0",
    "jest": "^30.2.0",
    "nodemon": "^3.0.1",
    "playwright": "^1.57.0"
  },
  "overrides": {
    "lodash": "^4.17.23",
    "qs": "^6.14.1"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
