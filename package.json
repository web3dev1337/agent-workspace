{
  "name": "claude-orchestrator",
  "version": "1.0.0",
  "description": "Multi-terminal orchestrator for Claude Code sessions",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "dev:client": "node client/dev-server.js",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:client\" \"npm run tauri:dev\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "claude",
    "ai",
    "orchestrator",
    "terminal",
    "websocket"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "concurrently": "^9.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "node-pty": "^1.0.0",
    "socket.io": "^4.6.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0-rc.18",
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
