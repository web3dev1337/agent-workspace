{
  "version": "1.1.0",
  "global": {
    "claudeFlags": {
      "skipPermissions": false,
      "provider": "anthropic"
    },
    "autoStart": {
      "enabled": false,
      "mode": "fresh",
      "delay": 500
    },
    "terminal": {},
    "ui": {
      "theme": "dark",
      "worktrees": {
        "autoCreateExtraWhenBusy": true,
        "autoCreateMinNumber": 9,
        "autoCreateMaxNumber": 25,
        "considerOtherWorkspaces": true
      },
      "workflow": {
        "mode": "review",
        "focus": {
          "hideTier2WhenTier1Busy": true,
          "autoSwapToTier2WhenTier1Busy": false
        },
        "notifications": {
          "mode": "quiet",
          "tier1Interrupts": true,
          "reviewCompleteNudges": true
        }
      },
      "tasks": {
        "theme": "inherit",
        "me": {
          "trelloUsername": ""
        },
        "boardMappings": {},
        "combined": {
          "selections": []
        },
        "automations": {
          "trello": {
            "onPrMerged": {
              "enabled": false,
              "pollEnabled": true,
              "webhookEnabled": false,
              "comment": true,
              "moveToDoneList": true,
              "closeIfNoDoneList": false,
              "pollMs": 60000
            }
          }
        },
        "kanban": {
          "collapsedByBoard": {},
          "expandedByBoard": {},
          "layoutByBoard": {}
        },
        "filters": {
          "assigneesByBoard": {}
        }
      },
      "diffViewer": {
        "theme": "dark"
      }
    }
  },
  "perTerminal": {}
}
