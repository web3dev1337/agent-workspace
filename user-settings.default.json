{
  "version": "1.1.0",
  "global": {
    "claudeFlags": {
      "skipPermissions": false,
      "provider": "anthropic"
    },
    "autoStart": {
      "enabled": false,
      "mode": "fresh",
      "delay": 500
    },
    "terminal": {},
    "scheduler": {
      "enabled": false,
      "tickSeconds": 30,
      "safety": {
        "defaultMode": "safe",
        "blockedCommandPatterns": [
          "queue-merge",
          "queue-request-changes",
          "queue-approve",
          "stop-session",
          "kill-session",
          "destroy-session",
          "remove-worktree"
        ]
      },
      "schedules": []
    },
    "ui": {
      "theme": "dark",
      "simpleMode": {
        "enabled": true,
        "startupOpen": false,
        "hotkeys": true,
        "showHints": true
      },
      "branches": {
        "hidePrefixes": true,
        "colorize": true,
        "showAtInSidebar": false
      },
      "terminals": {
        "viewMode": "all",
        "tierFilter": "all"
      },
      "worktrees": {
        "autoCreateExtraWhenBusy": true,
        "autoCreateMinNumber": 9,
        "autoCreateMaxNumber": 25,
        "considerOtherWorkspaces": true
      },
      "workflow": {
        "mode": "review",
        "focus": {
          "hideTier2WhenTier1Busy": true,
          "autoSwapToTier2WhenTier1Busy": false
        },
        "notifications": {
          "mode": "quiet",
          "tier1Interrupts": true,
          "reviewCompleteNudges": true
        }
      },
      "tasks": {
        "theme": "inherit",
        "me": {
          "trelloUsername": ""
        },
        "boardMappings": {},
        "boardConventions": {},
        "combined": {
          "selections": []
        },
        "automations": {
          "trello": {
            "onPrMerged": {
              "enabled": false,
              "pollEnabled": true,
              "webhookEnabled": false,
              "comment": true,
              "moveToDoneList": true,
              "closeIfNoDoneList": false,
              "pollMs": 60000
            }
          }
        },
        "kanban": {
          "collapsedByBoard": {},
          "expandedByBoard": {},
          "layoutByBoard": {}
        },
        "filters": {
          "assigneesByBoard": {}
        }
      },
      "identity": {
        "claimName": "",
        "saved": []
      },
      "diffViewer": {
        "theme": "dark"
      }
    }
  },
  "perTerminal": {}
}
