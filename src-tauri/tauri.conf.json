  "productName": "Claude Orchestrator",
  "version": "0.1.0",
  "identifier": "com.claude.orchestrator",
  "build": {
    "frontendDist": "../client",
    "devUrl": "http://localhost:2080",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
