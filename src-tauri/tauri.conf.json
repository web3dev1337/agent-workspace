{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agent Workspace",
  "version": "0.1.5-2",
  "identifier": "com.claude.orchestrator",
  "build": {
    "frontendDist": "bootstrap",
    "devUrl": "http://localhost:9461",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Agent Workspace",
        "width": 1600,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/backend/*",
      "resources/backend/config/**/*",
      "resources/backend/scripts/**/*",
      "resources/backend/server/**/*",
      "resources/backend/client/**/*",
      "resources/backend/templates/**/*",
      "resources/backend/node/*",
      "resources/backend/node_modules/**/*"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": ""
    }
  }
}
