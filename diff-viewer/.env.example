# GitHub API Token (required for fetching PR/commit data)
GITHUB_TOKEN=ghp_your_github_token_here

# Claude API Key (optional, for AI-powered summaries)
CLAUDE_API_KEY=sk-ant-your_claude_key_here

# Server Configuration
DIFF_VIEWER_PORT=9462
DIFF_VIEWER_HOST=127.0.0.1
NODE_ENV=development

# Security (off by default)
# DIFF_VIEWER_ENABLE_CORS=true
# DIFF_VIEWER_CORS_ORIGINS=http://127.0.0.1:9460,http://localhost:9460

# Feature Flags
ENABLE_AI_ANALYSIS=false
